{
    "$schema": "https://www.schemastore.org/npmpackagejsonlintrc.json",
    "extends": "npm-package-json-lint-config-nick2bad4u",
    "rules": {
        "no-absolute-version-devDependencies": "error",
        "prefer-caret-version-devDependencies": [
            "error",
            {
                "exceptions": [
                    "vitest-environment-browser"
                ]
            }
        ],
        "require-type": "off",
        "require-types": "off"
    }
}
